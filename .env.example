# Flask
SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_ENV=production

# Database (PostgreSQL)
DATABASE_URL=postgresql://lottery_app:change-this-password@127.0.0.1:5432/lottery_platform

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Production sizing for 2-core / 2GB host
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=300
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=5
# Web workers must not run background jobs. Use file-hub-scheduler.service instead.
ENABLE_SCHEDULER=0
DISABLE_SCHEDULER=1

# Aliyun OSS
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_DOMAIN=https://your-bucket.oss-cn-hangzhou.aliyuncs.com

# App settings
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Live concurrency acceptance test
RUN_LIVE_CONCURRENCY_TESTS=0
LIVE_TEST_SERVER_MODE=gunicorn
LIVE_TEST_GUNICORN_WORKERS=2
LIVE_TEST_STRICT_DEVICE_GUARD=1
LIVE_TEST_MODE_A_ACCOUNTS=20
LIVE_TEST_MODE_B_ACCOUNTS=10
LIVE_TEST_DEVICES_PER_ACCOUNT=10
LIVE_TEST_MODE_A_DEVICES_PER_ACCOUNT=2
LIVE_TEST_MODE_B_DEVICES_PER_ACCOUNT=6
LIVE_TEST_MODE_B_BATCH_COUNT=1
LIVE_TEST_MODE_A_REQUESTS_PER_DEVICE=1
LIVE_TEST_PENDING_HEADROOM=0
LIVE_TEST_MAX_SLOW_REQUESTS=20
